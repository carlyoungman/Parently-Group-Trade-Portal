{% doc %}
  @prompt
    6 image blocks in a row to click through to other pages
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-image-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-image-grid__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-image-grid__item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-image-grid__link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .ai-image-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
  }

  .ai-image-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-grid__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-grid__placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-image-grid__overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}), transparent);
    padding: 20px;
    opacity: {% if block.settings.show_text_on_hover %}0{% else %}1{% endif %};
    transition: opacity 0.3s ease;
  }

  .ai-image-grid__item-{{ ai_gen_id }}:hover .ai-image-grid__overlay-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-image-grid__title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0;
    font-weight: 600;
  }

  @media screen and (max-width: 989px) {
    .ai-image-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-image-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstyle %}

<div class="ai-image-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-grid__container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign title_key = 'title_' | append: i
        assign link_key = 'link_' | append: i
        
        assign image = block.settings[image_key]
        assign title = block.settings[title_key]
        assign link = block.settings[link_key]
      %}
      
      <div class="ai-image-grid__item-{{ ai_gen_id }}">
        {% if link != blank %}
          <a href="{{ link }}" class="ai-image-grid__link-{{ ai_gen_id }}">
        {% endif %}
        
        <div class="ai-image-grid__image-wrapper-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 600 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-image-grid__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-image-grid__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          
          {% if title != blank %}
            <div class="ai-image-grid__overlay-{{ ai_gen_id }}">
              <h3 class="ai-image-grid__title-{{ ai_gen_id }}">{{ title }}</h3>
            </div>
          {% endif %}
        </div>
        
        {% if link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

