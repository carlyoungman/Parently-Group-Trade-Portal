{
  "name": "parently-group-trade-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"shopify,sass\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail \"shopify theme dev --environment=dev\" \"npm run watch:css\"",
    "build": "npm run build:css && npm run build:js",
    "build:js": "vite build",
    "build:css": "sass assets/styles/theme.scss assets/theme.css --style=compressed --no-source-map",
    "build:css:dev": "sass assets/styles/theme.scss assets/theme.css --style=expanded --source-map",
    "watch:css": "sass --watch assets/styles/theme.scss:assets/theme.css --style=expanded --source-map",
    "lint": "stylelint 'assets/styles/**/*.scss' && eslint .",
    "lint:css": "stylelint 'assets/styles/**/*.scss'",
    "lint:js": "eslint .",
    "format": "prettier --write 'assets/styles/**/*.scss' 'assets/**/*.js' 'sections/**/*.liquid' 'snippets/**/*.liquid'",
    "format:css": "prettier --write 'assets/styles/**/*.scss'"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.4.0",
    "sass": "^1.80.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-order": "^6.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
