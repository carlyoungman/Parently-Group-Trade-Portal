{
  "name": "parently-group-trade-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sass --watch src/styles/entries:assets --load-path src/styles --no-source-map",
    "dev:react": "concurrently \"sass --watch src/styles/entries:assets --load-path src/styles --no-source-map\" \"vite build --watch\"",
    "build": "npm run build:css",
    "build:css": "sass src/styles/entries:assets --load-path src/styles --no-source-map --style=compressed",
    "build:react": "npm run build:css && vite build",
    "lint": "eslint . && stylelint 'src/styles/**/*.scss'",
    "lint:js": "eslint .",
    "lint:css": "stylelint 'src/styles/**/*.scss'",
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.4.0",
    "sass": "^1.80.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-order": "^6.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
