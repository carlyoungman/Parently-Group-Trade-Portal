{{ 'section-hero-banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_video = false
  if section.settings.video != blank
    assign has_video = true
  endif
-%}

{%- liquid
  assign mf = page.metafields.brand
  assign use_metafields = false
  if mf != blank
    assign use_metafields = true
  endif
  if use_metafields and mf.hero_image.value != blank
    assign banner_image = mf.hero_image.value
  else
    assign banner_image = section.settings.image
  endif
  if use_metafields and mf.hero_image_2.value != blank
    assign banner_image_2 = mf.hero_image_2.value
  else
    assign banner_image_2 = section.settings.image_2
  endif
-%}

{%- if section.settings.image_height == 'adapt' and banner_image != blank and has_video == false -%}
  {%- style -%}
    @media screen and (max-width: 749px) {
      #Banner-{{ section.id }}::before,
      #Banner-{{ section.id }} .banner__media::before,
      #Banner-{{ section.id }}:not(.banner--mobile-bottom) > .banner__content::before {
        padding-bottom: {{ 1 | divided_by: banner_image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }

    @media screen and (min-width: 750px) {
      #Banner-{{ section.id }}::before,
      #Banner-{{ section.id }} .banner__media::before {
        padding-bottom: {{ 1 | divided_by: banner_image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
  {%- endstyle -%}
{%- endif -%}

{%- style -%}
  #Banner-{{ section.id }}::after {
    opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
  }
  #Banner-{{ section.id }} .banner__media--image-1 img {
    object-position: {{ section.settings.image_position }};
  }
  #Banner-{{ section.id }} .banner__media--image-2 img {
    object-position: {{ section.settings.image_2_position }};
  }
  #Banner-{{ section.id }} .banner__media--video video {
    object-position: {{ section.settings.video_position }};
  }
{%- endstyle -%}

{%- if section.settings.white_text -%}
  {%- style -%}
    #Banner-{{ section.id }} .banner__heading,
    #Banner-{{ section.id }} .banner__text,
    #Banner-{{ section.id }} .banner__text p {
      color: #ffffff;
    }
    #Banner-{{ section.id }} .banner__buttons .button {
      color: #ffffff;
    }
  {%- endstyle -%}
{%- endif -%}

{%- liquid
  assign full_width = '100vw'
  assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'

  if section.settings.image_behavior == 'ambient'
    assign half_width = '60vw'
    assign full_width = '120vw'
    assign stacked_sizes = '(min-width: 750px) 60vw, 120vw'
    assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
  elsif section.settings.image_behavior == 'fixed' or section.settings.image_behavior == 'zoom-in'
    assign half_width = '100vw'
    assign stacked_sizes = '100vw'
  else
    assign half_width = '50vw'
    assign stacked_sizes = '(min-width: 750px) 50vw, 100vw'
  endif
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<div
  id="Banner-{{ section.id }}"
  class="banner banner--content-align-{{ section.settings.desktop_content_alignment }} banner--content-align-mobile-{{ section.settings.mobile_content_alignment }} banner--{{ section.settings.image_height }}{% if has_video == false and section.settings.stack_images_on_mobile and banner_image != blank and banner_image_2 != blank %} banner--stacked{% endif %}{% if section.settings.image_height == 'adapt' and banner_image != blank and has_video == false %} banner--adapt{% endif %}{% if section.settings.show_text_below %} banner--mobile-bottom{%- endif -%}{% if section.settings.show_text_box == false %} banner--desktop-transparent{% endif %}{% if has_video %} banner--has-video{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>
  {%- if has_video -%}
    <div class="banner__media banner__media--video media{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {{
        section.settings.video
        | video_tag:
          image_size: '1100x',
          autoplay: true,
          loop: true,
          controls: false,
          muted: true
      }}
    </div>
  {%- elsif banner_image != blank -%}
    <div class="banner__media banner__media--image-1 media{% if banner_image_2 != blank %} banner__media-half{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {%- liquid
        assign image_height = banner_image.width | divided_by: banner_image.aspect_ratio
        if banner_image_2 != blank
          assign image_class = 'banner__media-image-half'
        endif
        if banner_image_2 != blank and section.settings.stack_images_on_mobile
          assign sizes = stacked_sizes
        elsif banner_image_2 != blank
          assign sizes = half_width
        else
          assign sizes = full_width
        endif
      -%}
      {{
        banner_image
        | image_url: width: 3840
        | image_tag:
          width: banner_image.width,
          height: image_height,
          class: image_class,
          sizes: sizes,
          widths: widths,
          fetchpriority: fetch_priority
      }}
    </div>
  {%- elsif banner_image_2 == blank -%}
    <div class="banner__media media placeholder{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
    </div>
  {%- endif -%}

  {%- if banner_image_2 != blank and has_video == false -%}
    <div class="banner__media banner__media--image-2 media{% if banner_image != blank %} banner__media-half{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {%- liquid
        assign image_height_2 = banner_image_2.width | divided_by: banner_image_2.aspect_ratio
        if banner_image != blank
          assign image_class_2 = 'banner__media-image-half'
        endif
        if banner_image != blank and section.settings.stack_images_on_mobile
          assign sizes = stacked_sizes
        elsif banner_image_2 != blank
          assign sizes = half_width
        else
          assign sizes = full_width
        endif
      -%}
      {{
        banner_image_2
        | image_url: width: 3840
        | image_tag:
          width: banner_image_2.width,
          height: image_height_2,
          class: image_class_2,
          sizes: sizes,
          widths: widths,
          fetchpriority: fetch_priority
      }}
    </div>
  {%- endif -%}

  <div class="banner__content banner__content--{{ section.settings.desktop_content_position }} page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <div class="banner__box content-container content-container--full-width-mobile color-scheme-1">
      <div class="banner__content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'image' -%}
              {%- if use_metafields and mf.hero_logo.value != blank -%}
                {%- assign banner_logo = mf.hero_logo.value -%}
              {%- else -%}
                {%- assign banner_logo = block.settings.image -%}
              {%- endif -%}
              {%- if banner_logo != blank -%}
                <div class="banner__content-image banner__content-image--{{ block.settings.image_width }}" {{ block.shopify_attributes }}>
                  {{
                    banner_logo
                    | image_url: width: 800
                    | image_tag:
                      width: banner_logo.width,
                      height: banner_logo.height,
                      class: 'banner__content-image-img'
                  }}
                </div>
              {%- endif -%}
            {%- when 'heading' -%}
              {%- if use_metafields and mf.hero_heading.value != blank -%}
                {%- assign banner_heading = mf.hero_heading.value -%}
              {%- else -%}
                {%- assign banner_heading = block.settings.heading -%}
              {%- endif -%}
              {%- if banner_heading != blank -%}
                <h2
                  class="banner__heading inline-richtext {{ block.settings.heading_size }}"
                  {{ block.shopify_attributes }}
                >
                  {{ banner_heading }}
                </h2>
              {%- endif -%}
            {%- when 'text' -%}
              {%- if use_metafields and mf.hero_text.value != blank -%}
                {%- assign banner_text = mf.hero_text.value -%}
              {%- else -%}
                {%- assign banner_text = block.settings.text -%}
              {%- endif -%}
              {%- if banner_text != blank -%}
                <div class="banner__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                  <p>{{ banner_text }}</p>
                </div>
              {%- endif -%}
            {%- when 'buttons' -%}
              {%- liquid
                if use_metafields and mf.hero_button_label_1.value != blank
                  assign btn1_label = mf.hero_button_label_1.value
                else
                  assign btn1_label = block.settings.button_label_1
                endif
                if use_metafields and mf.hero_button_link_1.value != blank
                  assign btn1_link = mf.hero_button_link_1.value
                else
                  assign btn1_link = block.settings.button_link_1
                endif
                if use_metafields and mf.hero_button_label_2.value != blank
                  assign btn2_label = mf.hero_button_label_2.value
                else
                  assign btn2_label = block.settings.button_label_2
                endif
                if use_metafields and mf.hero_button_link_2.value != blank
                  assign btn2_link = mf.hero_button_link_2.value
                else
                  assign btn2_link = block.settings.button_link_2
                endif
              -%}
              <div
                class="banner__buttons{% if btn1_label != blank and btn2_label != blank %} banner__buttons--multiple{% endif %}"
                {{ block.shopify_attributes }}
              >
                {%- if btn1_label != blank -%}
                  <a
                    {% if btn1_link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ btn1_link }}"
                    {% endif %}
                    class="button{% if block.settings.button_style_secondary_1 %} button--secondary{% else %} button--primary{% endif %}"
                  >
                    {{- btn1_label | escape -}}
                  </a>
                {%- endif -%}
                {%- if btn2_label != blank -%}
                  <a
                    {% if btn2_link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ btn2_link }}"
                    {% endif %}
                    class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}"
                  >
                    {{- btn2_label | escape -}}
                  </a>
                {%- endif -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.hero-banner.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.hero-banner.settings.header_video.content"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.hero-banner.settings.video.label"
    },
    {
      "type": "select",
      "id": "video_position",
      "label": "Video position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "top center", "label": "Top" },
        { "value": "bottom center", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" },
        { "value": "top left", "label": "Top left" },
        { "value": "top right", "label": "Top right" },
        { "value": "bottom left", "label": "Bottom left" },
        { "value": "bottom right", "label": "Bottom right" }
      ],
      "default": "center center"
    },
    {
      "type": "header",
      "content": "t:sections.hero-banner.settings.header_image.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image-banner.settings.image.label"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image 1 position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "top center", "label": "Top" },
        { "value": "bottom center", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" },
        { "value": "top left", "label": "Top left" },
        { "value": "top right", "label": "Top right" },
        { "value": "bottom left", "label": "Bottom left" },
        { "value": "bottom right", "label": "Bottom right" }
      ],
      "default": "center center"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "t:sections.image-banner.settings.image_2.label"
    },
    {
      "type": "select",
      "id": "image_2_position",
      "label": "Image 2 position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "top center", "label": "Top" },
        { "value": "bottom center", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" },
        { "value": "top left", "label": "Top left" },
        { "value": "top right", "label": "Top right" },
        { "value": "bottom left", "label": "Bottom left" },
        { "value": "bottom right", "label": "Bottom right" }
      ],
      "default": "center center"
    },
    {
      "type": "paragraph",
      "content": "t:sections.hero-banner.settings.image_2_video_note.content"
    },
    {
      "type": "range",
      "id": "image_overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "t:sections.image-banner.settings.image_overlay_opacity.label",
      "default": 0
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.image-banner.settings.image_height.options__1.label"
        },
        {
          "value": "small",
          "label": "t:sections.image-banner.settings.image_height.options__2.label"
        },
        {
          "value": "medium",
          "label": "t:sections.image-banner.settings.image_height.options__3.label"
        },
        {
          "value": "large",
          "label": "t:sections.image-banner.settings.image_height.options__4.label"
        }
      ],
      "default": "medium",
      "label": "t:sections.image-banner.settings.image_height.label"
    },
    {
      "type": "select",
      "id": "image_behavior",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.animation.image_behavior.options__1.label"
        },
        {
          "value": "ambient",
          "label": "t:sections.all.animation.image_behavior.options__2.label"
        },
        {
          "value": "fixed",
          "label": "t:sections.all.animation.image_behavior.options__3.label"
        },
        {
          "value": "zoom-in",
          "label": "t:sections.all.animation.image_behavior.options__4.label"
        }
      ],
      "default": "none",
      "label": "t:sections.all.animation.image_behavior.label",
      "info": "t:sections.hero-banner.settings.image_behavior.info"
    },
    {
      "type": "header",
      "content": "t:sections.image-banner.settings.content.content"
    },
    {
      "type": "checkbox",
      "id": "white_text",
      "default": false,
      "label": "t:sections.hero-banner.settings.white_text.label"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "options": [
        {
          "value": "top-left",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__1.label"
        },
        {
          "value": "top-center",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__2.label"
        },
        {
          "value": "top-right",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__3.label"
        },
        {
          "value": "middle-left",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__4.label"
        },
        {
          "value": "middle-center",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__5.label"
        },
        {
          "value": "middle-right",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__6.label"
        },
        {
          "value": "bottom-left",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__7.label"
        },
        {
          "value": "bottom-center",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__8.label"
        },
        {
          "value": "bottom-right",
          "label": "t:sections.image-banner.settings.desktop_content_position.options__9.label"
        }
      ],
      "default": "middle-center",
      "label": "t:sections.image-banner.settings.desktop_content_position.label"
    },
    {
      "type": "select",
      "id": "desktop_content_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image-banner.settings.desktop_content_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.image-banner.settings.desktop_content_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.image-banner.settings.desktop_content_alignment.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.image-banner.settings.desktop_content_alignment.label"
    },
    {
      "type": "checkbox",
      "id": "show_text_box",
      "default": true,
      "label": "t:sections.image-banner.settings.show_text_box.label"
    },
    {
      "type": "header",
      "content": "t:sections.image-banner.settings.mobile.content"
    },
    {
      "type": "checkbox",
      "id": "stack_images_on_mobile",
      "default": true,
      "label": "t:sections.image-banner.settings.stack_images_on_mobile.label"
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image-banner.settings.mobile_content_alignment.options__1.label"
