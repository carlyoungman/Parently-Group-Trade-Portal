{%- render 'section-padding-style' -%}

<div class="key-points-list color-scheme-1 section-{{ section.id }}-padding">
  <div class="key-points-list__inner page-width">

    {%- comment -%} LEFT COLUMN — heading, text, buttons {%- endcomment -%}
    <div class="key-points-list__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'heading' -%}
            {%- if block.settings.heading != blank -%}
              <h2
                class="key-points-list__heading inline-richtext {{ block.settings.heading_size }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.heading }}
              </h2>
            {%- endif -%}

          {%- when 'text' -%}
            {%- if block.settings.text != blank -%}
              <div
                class="key-points-list__text rte"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>
            {%- endif -%}

          {%- when 'buttons' -%}
            {%- render 'button-pair',
              button_label_1: block.settings.button_label_1,
              button_link_1: block.settings.button_link_1,
              button_style_secondary_1: block.settings.button_style_secondary_1,
              button_label_2: block.settings.button_label_2,
              button_link_2: block.settings.button_link_2,
              button_style_secondary_2: block.settings.button_style_secondary_2,
              container_class: 'key-points-list__buttons',
              shopify_attributes: block.shopify_attributes
            -%}

        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} RIGHT COLUMN — key points grid {%- endcomment -%}
    <div class="key-points-list__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'key_point' -%}
          <div class="key-points-list__point" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h3 class="key-points-list__point-heading inline-richtext">
                {{ block.settings.heading }}
              </h3>
            {%- endif -%}
            {%- if block.settings.content != blank -%}
              <div class="key-points-list__point-body rte">
                {{ block.settings.content }}
              </div>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <div class="key-points-list__point-button">
                <a
                  {% if block.settings.button_link == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link }}"
                  {% endif %}
                  class="button{% if block.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{ block.settings.button_label | escape }}
                </a>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Key points list",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Why the Parently Group...",
          "label": "Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "t:sections.all.heading_size.label",
          "default": "h2",
          "options": [
            { "value": "supersize", "label": "t:sections.all.heading_size.options__1.label" },
            { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
            { "value": "h2", "label": "t:sections.all.heading_size.options__3.label" },
            { "value": "h3", "label": "t:sections.all.heading_size.options__4.label" },
            { "value": "h4", "label": "t:sections.all.heading_size.options__5.label" },
            { "value": "h5", "label": "t:sections.all.heading_size.options__6.label" },
            { "value": "h6", "label": "t:sections.all.heading_size.options__7.label" },
            { "value": "small", "label": "t:sections.all.heading_size.options__8.label" }
          ]
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>What we can bring to every partnership, across every brand.</p>",
          "label": "Content"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Button 1"
        },
        {
          "type": "text",
          "id": "button_label_1",
          "label": "Button label",
          "default": "Become a retailer",
          "info": "Leave blank to hide this button."
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary_1",
          "label": "Use outline style",
          "default": true
        },
        {
          "type": "header",
          "content": "Button 2"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Button label",
          "info": "Leave blank to hide this button."
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary_2",
          "label": "Use outline style",
          "default": true
        }
      ]
    },
    {
      "type": "@app"
    },
    {
      "type": "key_point",
      "name": "Key point",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Key point heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "default": "<p>Describe this key point in a short, clear sentence or two.</p>",
          "label": "Content"
        },
        {
          "type": "header",
          "content": "Button (optional)"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "info": "Leave blank to hide the button."
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary",
          "label": "Use outline style",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Key points list",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "buttons" },
        { "type": "key_point" },
        { "type": "key_point" },
        { "type": "key_point" },
        { "type": "key_point" }
      ]
    }
  ]
}
{% endschema %}
