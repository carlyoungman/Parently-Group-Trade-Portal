{%- render 'section-padding-style' -%}

{%- liquid
  assign mf = page.metafields.brand
  assign use_metafields = false
  if mf != blank
    assign use_metafields = true
    assign mf_image_1        = mf.grid_image_1.value
    assign mf_image_2        = mf.grid_image_2.value
    assign mf_image_3        = mf.grid_image_3.value
    assign mf_heading        = mf.grid_heading.value
    assign mf_content        = mf.grid_content.value
    assign mf_btn1_label     = mf.grid_button_label_1.value
    assign mf_btn1_link      = mf.grid_button_link_1.value
    assign mf_btn2_label     = mf.grid_button_label_2.value
    assign mf_btn2_link      = mf.grid_button_link_2.value
    assign mf_bg_color       = mf.grid_content_bg_color.value
    assign mf_text_color     = mf.grid_text_color.value
  endif
  if use_metafields
    if mf_image_1 != blank
      assign grid_image_1 = mf_image_1
    else
      assign grid_image_1 = section.settings.image_1
    endif
    if mf_image_2 != blank
      assign grid_image_2 = mf_image_2
    else
      assign grid_image_2 = section.settings.image_2
    endif
    if mf_image_3 != blank
      assign grid_image_3 = mf_image_3
    else
      assign grid_image_3 = section.settings.image_3
    endif
    if mf_heading != blank
      assign grid_heading = mf_heading
    else
      assign grid_heading = section.settings.heading
    endif
    if mf_content != blank
      assign grid_content = mf_content
    else
      assign grid_content = section.settings.content
    endif
    if mf_btn1_label != blank
      assign grid_btn1_label = mf_btn1_label
    else
      assign grid_btn1_label = section.settings.button_label_1
    endif
    if mf_btn1_link != blank
      assign grid_btn1_link = mf_btn1_link
    else
      assign grid_btn1_link = section.settings.button_link_1
    endif
    if mf_btn2_label != blank
      assign grid_btn2_label = mf_btn2_label
    else
      assign grid_btn2_label = section.settings.button_label_2
    endif
    if mf_btn2_link != blank
      assign grid_btn2_link = mf_btn2_link
    else
      assign grid_btn2_link = section.settings.button_link_2
    endif
    if mf_bg_color != blank
      assign grid_bg_color = mf_bg_color
    else
      assign grid_bg_color = section.settings.content_bg_color
    endif
    if mf_text_color != blank
      assign grid_text_color = mf_text_color
    else
      assign grid_text_color = section.settings.text_color
    endif
  else
    assign grid_image_1   = section.settings.image_1
    assign grid_image_2   = section.settings.image_2
    assign grid_image_3   = section.settings.image_3
    assign grid_heading   = section.settings.heading
    assign grid_content   = section.settings.content
    assign grid_btn1_label = section.settings.button_label_1
    assign grid_btn1_link  = section.settings.button_link_1
    assign grid_btn2_label = section.settings.button_label_2
    assign grid_btn2_link  = section.settings.button_link_2
    assign grid_bg_color  = section.settings.content_bg_color
    assign grid_text_color = section.settings.text_color
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .image-grid-with-content__content {
    background-color: {{ grid_bg_color }};
    color: {{ grid_text_color }};
  }
{%- endstyle -%}

<div class="image-grid-with-content section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="image-grid-with-content__layout{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">

      <div class="image-grid-with-content__images">

        {%- liquid
          assign fetch_priority = 'auto'
          if section.index == 1
            assign fetch_priority = 'high'
          endif
        -%}

        <div class="image-grid-with-content__image-item">
          {%- if grid_image_1 != blank -%}
            {{
              grid_image_1
              | image_url: width: 1200
              | image_tag:
                widths: '400, 600, 900, 1200',
                sizes: '(min-width: 990px) 35vw, (min-width: 750px) 45vw, 100vw',
                loading: 'lazy',
                fetchpriority: fetch_priority,
                class: 'image-grid-with-content__image'
            }}
          {%- else -%}
            <span class="image-grid-with-content__placeholder">
              {{- 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' -}}
            </span>
          {%- endif -%}
        </div>

        <div class="image-grid-with-content__image-row">

          <div class="image-grid-with-content__image-item">
            {%- if grid_image_2 != blank -%}
              {{
                grid_image_2
                | image_url: width: 600
                | image_tag:
                  widths: '200, 300, 400, 600',
                  sizes: '(min-width: 990px) 17vw, (min-width: 750px) 22vw, 50vw',
                  loading: 'lazy',
                  class: 'image-grid-with-content__image'
              }}
            {%- else -%}
              <span class="image-grid-with-content__placeholder">
                {{- 'detailed-apparel-2' | placeholder_svg_tag: 'placeholder-svg' -}}
              </span>
            {%- endif -%}
          </div>

          <div class="image-grid-with-content__image-item">
            {%- if grid_image_3 != blank -%}
              {{
                grid_image_3
                | image_url: width: 600
                | image_tag:
                  widths: '200, 300, 400, 600',
                  sizes: '(min-width: 990px) 17vw, (min-width: 750px) 22vw, 50vw',
                  loading: 'lazy',
                  class: 'image-grid-with-content__image'
              }}
            {%- else -%}
              <span class="image-grid-with-content__placeholder">
                {{- 'collection-apparel-2' | placeholder_svg_tag: 'placeholder-svg' -}}
              </span>
            {%- endif -%}
          </div>

        </div>
      </div>

      {%- assign text_color_lower = grid_text_color | downcase -%}
      {%- assign is_white_text = false -%}
      {%- if text_color_lower == '#ffffff' or text_color_lower == '#fff' or text_color_lower == 'white' -%}
        {%- assign is_white_text = true -%}
      {%- endif -%}
      <div class="image-grid-with-content__content{% if is_white_text %} image-grid-with-content__content--white-text{% endif %}">

        {%- unless grid_heading == blank -%}
          <h2 class="image-grid-with-content__heading inline-richtext {{ section.settings.heading_size }}">
            {{ grid_heading }}
          </h2>
        {%- endunless -%}

        {%- unless grid_content == blank -%}
          <div class="image-grid-with-content__text rte">
            {{ grid_content }}
          </div>
        {%- endunless -%}

        {%- render 'button-pair',
          button_label_1: grid_btn1_label,
          button_link_1: grid_btn1_link,
          button_style_secondary_1: section.settings.button_style_secondary_1,
          button_label_2: grid_btn2_label,
          button_link_2: grid_btn2_link,
          button_style_secondary_2: section.settings.button_style_secondary_2,
          container_class: 'image-grid-with-content__buttons'
        -%}

      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image grid with content",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 (primary – top)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (bottom left)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 (bottom right)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Colour changing technology",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "supersize", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h2", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "h3", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "h4", "label": "t:sections.all.heading_size.options__5.label" },
        { "value": "h5", "label": "t:sections.all.heading_size.options__6.label" },
        { "value": "h6", "label": "t:sections.all.heading_size.options__7.label" },
        { "value": "small", "label": "t:sections.all.heading_size.options__8.label" },
        { "value": "h0", "label": "Extra large" }
      ]
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "info": "Optional body text displayed below the heading."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button 1 label",
      "info": "Leave blank to hide."
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button 1 link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary_1",
      "label": "Button 1 — use outline style",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 label",
      "info": "Leave blank to hide."
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary_2",
      "label": "Button 2 — use outline style",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "content_bg_color",
      "label": "Content background colour",
      "default": "#0099a8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Image grid with content"
    }
  ]
}
{% endschema %}
