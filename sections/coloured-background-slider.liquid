{%- render 'section-padding-style' -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --cbs-bg: {{ section.settings.background_color }};
    --cbs-image-ratio: {{ section.settings.image_ratio | replace: '-', ' / ' }};
  }
{%- endstyle -%}

<div class="coloured-background-slider section-{{ section.id }}-padding">

  {%- comment -%} Section header — page-width constrained, above the coloured strip {%- endcomment -%}
  {%- render 'section-heading-group',
    heading: section.settings.heading,
    heading_size: section.settings.heading_size,
    content: section.settings.content,
    button_label_1: section.settings.button_label_1,
    button_link_1: section.settings.button_link_1,
    button_style_secondary_1: section.settings.button_style_secondary_1,
    button_label_2: section.settings.button_label_2,
    button_link_2: section.settings.button_link_2,
    button_style_secondary_2: section.settings.button_style_secondary_2,
    wrapper_class: 'coloured-background-slider__header page-width',
    heading_class: 'coloured-background-slider__heading',
    content_text_class: 'coloured-background-slider__section-content',
    button_container_class: 'coloured-background-slider__section-buttons'
  -%}

  {%- comment -%} Full-bleed coloured strip with image carousel {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div
      class="coloured-background-slider__background{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      style="background-color: var(--cbs-bg);"
    > </div>
      <slider-component
        class="coloured-background-slider__slider-component"
        data-autoplay="{{ section.settings.autoplay }}"
        data-autoplay-speed="{{ section.settings.autoplay_speed }}"
      >

        <ul
          id="Slider-{{ section.id }}"
          class="coloured-background-slider__track slider slider--everywhere"
          role="list"
          aria-live="polite"
          aria-atomic="true"
        >
          {%- for block in section.blocks -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="coloured-background-slider__slide slider__slide"
              {{ block.shopify_attributes }}
              role="group"
              aria-roledescription="slide"
              aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
              tabindex="-1"
            >
              <div class="coloured-background-slider__slide-image-wrapper">
                {%- if block.settings.image != blank -%}
                  {%- liquid
                    assign fetch_priority = 'auto'
                    if section.index == 1 and forloop.first
                      assign fetch_priority = 'high'
                    endif
                  -%}
                  {{
                    block.settings.image
                    | image_url: width: 900
                    | image_tag:
                      widths: '300, 450, 600, 900',
                      sizes: '(min-width: 990px) 34rem, (min-width: 750px) 30rem, 24rem',
                      loading: 'lazy',
                      fetchpriority: fetch_priority,
                      class: 'coloured-background-slider__image'
                  }}
                {%- else -%}
                  {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg coloured-background-slider__placeholder' }}
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>

        {%- if section.blocks.size > 1 -%}
          <div class="coloured-background-slider__nav">
            <button
              type="button"
              class="slider-button slider-button--prev coloured-background-slider__nav-btn"
              name="previous"
              aria-label="{{ 'general.slider.previous_slide' | t }}"
              aria-controls="Slider-{{ section.id }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </button>

            <div class="coloured-background-slider__dots" role="tablist" aria-label="{{ section.settings.heading | strip_html | escape }}">
              {%- for block in section.blocks -%}
                <button
                  type="button"
                  class="coloured-background-slider__dot-btn{% if forloop.first %} slider-counter__link--active{% endif %}"
                  aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                  aria-controls="Slider-{{ section.id }}"
                  aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
                  role="tab"
                >
                  <span class="coloured-background-slider__dot"></span>
                </button>
              {%- endfor -%}
            </div>

            <button
              type="button"
              class="slider-button slider-button--next coloured-background-slider__nav-btn"
              name="next"
              aria-label="{{ 'general.slider.next_slide' | t }}"
              aria-controls="Slider-{{ section.id }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>
        {%- endif -%}

      </slider-component>

  {%- endif -%}

</div>

<script>
(function () {
  var section = document.getElementById('shopify-section-{{ section.id }}');
  if (!section) return;

  var sliderEl = section.querySelector('slider-component');
  var slider   = sliderEl && sliderEl.querySelector('[id^="Slider-"]');
  var dots     = sliderEl ? Array.from(sliderEl.querySelectorAll('.coloured-background-slider__dot-btn')) : [];
  if (!slider) return;

  var origSlides = Array.from(slider.querySelectorAll('[id^="Slide-"]'));
  var origCount  = origSlides.length;
  var allSlides  = origSlides.slice(); // expanded to 3× by setupLoop
  var setWidth   = 0;
  var jumping    = false;

  // Keep SliderComponent's prev/next buttons enabled at all times
  if (origCount > 1) sliderEl.enableSliderLooping = true;

  // ── Build prepend + append clone sets ────────────────────
  function setupLoop() {
    if (origCount < 2) return;

    function mkClone(s) {
      var c = s.cloneNode(true);
      c.removeAttribute('id');
      c.setAttribute('aria-hidden', 'true');
      c.classList.add('cbs-clone');
      return c;
    }

    // Prepend clones (insert reversed so they end up in forward order)
    origSlides.slice().reverse().forEach(function (s) {
      slider.insertBefore(mkClone(s), slider.firstChild);
    });

    // Append clones
    origSlides.forEach(function (s) { slider.appendChild(mkClone(s)); });

    // Full slide list: [n prepend clones | n originals | n append clones]
    allSlides = Array.from(slider.querySelectorAll('.coloured-background-slider__slide'));

    // Width of one full set (distance between matching slides in adjacent sets)
    setWidth = allSlides[origCount].offsetLeft - allSlides[0].offsetLeft;

    // Scroll to show the original set on load
    var firstOrig = allSlides[origCount];
    slider.style.scrollBehavior = 'auto';
    slider.scrollLeft = Math.max(0, firstOrig.offsetLeft - slider.clientWidth / 2 + firstOrig.offsetWidth / 2);
    slider.style.scrollBehavior = '';
  }

  // ── Index helpers ─────────────────────────────────────────
  // Index of the slide whose centre is nearest to the viewport centre
  function centredIdx() {
    var c = slider.scrollLeft + slider.clientWidth / 2;
    var best = 0, bestD = Infinity;
    allSlides.forEach(function (s, i) {
      var d = Math.abs((s.offsetLeft + s.offsetWidth / 2) - c);
      if (d < bestD) { bestD = d; best = i; }
    });
    return best;
  }

  // Map any allSlides index (including clones) → 0..origCount-1
  function toOrig(i) {
    return ((i - origCount) % origCount + origCount) % origCount;
  }

  // ── Seamless loop reset after scroll settles ─────────────
  function loopReset() {
    if (jumping || !setWidth) return;
    var ci    = centredIdx();
    var delta = 0;
    if (ci >= 2 * origCount) delta = -setWidth; // in append clones → jump back
    else if (ci < origCount) delta =  setWidth;  // in prepend clones → jump forward
    if (!delta) return;

    jumping = true;
    slider.style.scrollBehavior = 'auto';
    slider.scrollLeft += delta;
    slider.style.scrollBehavior = '';
    requestAnimationFrame(function () { jumping = false; updateUI(); });
  }

  // ── Dot & active-slide state ──────────────────────────────
  function updateUI() {
    var origIdx = toOrig(centredIdx());
    allSlides.forEach(function (s, i) {
      s.classList.toggle('is-active', toOrig(i) === origIdx);
    });
    dots.forEach(function (d, i) {
      d.classList.toggle('slider-counter__link--active', i === origIdx);
      d.setAttribute('aria-current', i === origIdx ? 'true' : 'false');
    });
  }

  // ── Scroll listeners ──────────────────────────────────────
  var uiTimer, resetTimer;
  slider.addEventListener('scroll', function () {
    if (jumping) return;
    clearTimeout(uiTimer);    uiTimer    = setTimeout(updateUI,   80);
    clearTimeout(resetTimer);
    resetTimer = setTimeout(loopReset, 150);
  });

  // ── Dot navigation — always target original slides ────────
  dots.forEach(function (dot, idx) {
    dot.addEventListener('click', function () {
      var s = origSlides[idx];
      if (!s) return;
      slider.scrollTo({ left: Math.max(0, s.offsetLeft - slider.clientWidth / 2 + s.offsetWidth / 2), behavior: 'smooth' });
    });
  });

  // ── Autoplay ──────────────────────────────────────────────
  var autoplay = sliderEl.dataset.autoplay === 'true';
  var speed    = (parseFloat(sliderEl.dataset.autoplaySpeed) || 4) * 1000;
  var apTimer  = null;

  function nextSlide() {
    var ci   = centredIdx();
    var next = Math.min(ci + 1, allSlides.length - 1);
    var s    = allSlides[next];
    slider.scrollTo({ left: Math.max(0, s.offsetLeft - slider.clientWidth / 2 + s.offsetWidth / 2), behavior: 'smooth' });
  }

  function startAutoplay() { if (autoplay) apTimer = setInterval(nextSlide, speed); }
  function stopAutoplay()  { clearInterval(apTimer); apTimer = null; }

  if (autoplay) {
    sliderEl.addEventListener('mouseenter', stopAutoplay);
    sliderEl.addEventListener('mouseleave', startAutoplay);
    startAutoplay();
  }

  // ── Init ──────────────────────────────────────────────────
  setupLoop();
  updateUI();
})();
</script>

{% schema %}
{
  "name": "Colour background slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Our Collection",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "supersize", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h2", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "h3", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "h4", "label": "t:sections.all.heading_size.options__5.label" },
        { "value": "h5", "label": "t:sections.all.heading_size.options__6.label" },
        { "value": "h6", "label": "t:sections.all.heading_size.options__7.label" },
        { "value": "small", "label": "t:sections.all.heading_size.options__8.label" },
        { "value": "h0", "label": "Extra large" }
      ]
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "info": "Optional body text displayed below the section heading."
    },
    {
      "type": "header",
      "content": "Section buttons"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button 1 label",
      "info": "Leave blank to hide."
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button 1 link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary_1",
      "label": "Button 1 — use outline style",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 label",
      "info": "Leave blank to hide."
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary_2",
      "label": "Button 2 — use outline style",
      "default": true
    },
    {
      "type": "header",
      "content": "Slider appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#0099a8"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "default": "3-4",
      "options": [
        { "value": "1-1", "label": "1:1 — Square" },
        { "value": "4-3", "label": "4:3 — Landscape" },
        { "value": "3-4", "label": "3:4 — Portrait" },
        { "value": "16-9", "label": "16:9 — Widescreen" },
        { "value": "auto", "label": "Auto — Follow image" }
      ]
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 1,
      "max": 10,
      "step": 0.5,
      "unit": "s",
      "label": "Change slides every",
      "default": 4
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Colour background slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
