{%- render 'section-padding-style' -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign columns_desktop_int = section.settings.columns_desktop | plus: 0
  assign skip_card_product_styles = false
-%}


<div class="color-scheme-1 isolate">
  <tabbed-featured-collections
    class="tabbed-collections section-{{ section.id }}-padding"
    id="TabbedCollections-{{ section.id }}"
  >
    <div class="tabbed-collections__inner page-width">
    {%- if section.blocks.size == 0 -%}
      {%- render 'empty-state-message',
        message: 'Add tab blocks in the theme editor to get started.',
        class: 'tabbed-collections__empty'
      -%}
    {%- else -%}

      <div
        class="tabbed-collections__tab-bar"
        role="tablist"
        aria-label="Product collection tabs"
      >
        {%- for block in section.blocks -%}
          <button
            type="button"
            class="tabbed-collections__tab{% if forloop.first %} tabbed-collections__tab--active{% endif %}"
            id="Tab-{{ block.id }}-{{ section.id }}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="Panel-{{ block.id }}-{{ section.id }}"
            tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.tab_title | default: 'Tab' | escape }}
          </button>
        {%- endfor -%}
      </div>

      {%- for block in section.blocks -%}
        <div
          id="Panel-{{ block.id }}-{{ section.id }}"
          class="tabbed-collections__panel"
          role="tabpanel"
          aria-labelledby="Tab-{{ block.id }}-{{ section.id }}"
          tabindex="0"
          {% unless forloop.first %}hidden{% endunless %}
        >
          {%- assign tab_collection = block.settings.collection -%}

          {%- if tab_collection != blank and tab_collection.products.size > 0 -%}
            <ul
              class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ columns_desktop_int }}-col-desktop grid--{{ columns_mobile_int }}-col-tablet-down"
              role="list"
            >
              {%- for product in tab_collection.products limit: section.settings.products_to_show -%}
                <li class="grid__item">
                  {%- render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    lazy_load: true,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    skip_styles: skip_card_product_styles,
                    section_id: section.id,
                    quick_add: 'none'
                  -%}
                </li>
                {%- assign skip_card_product_styles = true -%}
              {%- endfor -%}
            </ul>

          {%- elsif tab_collection != blank and tab_collection.products.size == 0 -%}
            {%- render 'empty-state-message',
              message: 'This collection has no products yet.',
              class: 'tabbed-collections__panel-empty'
            -%}

          {%- else -%}
            <ul
              class="grid product-grid contains-card contains-card--product grid--{{ columns_desktop_int }}-col-desktop grid--{{ columns_mobile_int }}-col-tablet-down"
              role="list"
            >
              {%- for i in (1..columns_desktop_int) -%}
                <li class="grid__item">
                  {%- assign placeholder_image = 'product-apparel-' | append: forloop.index -%}
                  {%- render 'card-product',
                    media_aspect_ratio: section.settings.image_ratio,
                    lazy_load: false,
                    placeholder_image: placeholder_image,
                    skip_styles: skip_card_product_styles
                  -%}
                </li>
                {%- assign skip_card_product_styles = true -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}

        </div>
      {%- endfor -%}

    {%- endif -%}
    </div>
  </tabbed-featured-collections>
</div>

<script>
  class TabbedFeaturedCollections extends HTMLElement {
    constructor() {
      super();
      this.tabs = Array.from(this.querySelectorAll('[role="tab"]'));
      this.panels = Array.from(this.querySelectorAll('[role="tabpanel"]'));
      if (!this.tabs.length) return;
      this.tabs.forEach((tab) => {
        tab.addEventListener('click', this.onTabClick.bind(this));
        tab.addEventListener('keydown', this.onKeyDown.bind(this));
      });
    }

    onTabClick(event) {
      this.activateTab(event.currentTarget);
    }

    onKeyDown(event) {
      const index = this.tabs.indexOf(event.currentTarget);
      let newIndex;
      if (event.key === 'ArrowRight') newIndex = (index + 1) % this.tabs.length;
      else if (event.key === 'ArrowLeft') newIndex = (index - 1 + this.tabs.length) % this.tabs.length;
      else if (event.key === 'Home') newIndex = 0;
      else if (event.key === 'End') newIndex = this.tabs.length - 1;
      else return;
      event.preventDefault();
      this.activateTab(this.tabs[newIndex]);
      this.tabs[newIndex].focus();
    }

    activateTab(activeTab) {
      this.tabs.forEach((tab) => {
        const isActive = tab === activeTab;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
        tab.classList.toggle('tabbed-collections__tab--active', isActive);
      });
      const controlled = activeTab.getAttribute('aria-controls');
      this.panels.forEach((panel) => {
        if (panel.id === controlled) {
          panel.removeAttribute('hidden');
        } else {
          panel.setAttribute('hidden', '');
        }
      });
    }
  }

  if (!customElements.get('tabbed-featured-collections')) {
    customElements.define('tabbed-featured-collections', TabbedFeaturedCollections);
  }
</script>

{% schema %}
{
  "name": "Tab Featured Collections",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Product Grid"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 25,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "Number of columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ]
    },
    {
      "type": "header",
      "content": "Card appearance"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "default": "adapt",
      "label": "Image ratio",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show second image on hover"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show product vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show product rating",
      "info": "To display a rating, add a product rating app."
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab label",
          "default": "New Arrivals"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tabbed Featured Collections",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "tab_title": "New Arrivals"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_title": "Best Sellers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
