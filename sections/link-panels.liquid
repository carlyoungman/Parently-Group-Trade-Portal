{%- render 'section-padding-style' -%}

<div class="link-panels color-scheme-1 section-{{ section.id }}-padding">
  <div class="page-width">

    {%- render 'section-heading-group',
      heading: section.settings.heading,
      heading_size: section.settings.heading_size,
      content: section.settings.content,
      button_label_1: section.settings.button_label_1,
      button_link_1: section.settings.button_link_1,
      button_style_secondary_1: section.settings.button_style_secondary_1,
      button_label_2: section.settings.button_label_2,
      button_link_2: section.settings.button_link_2,
      button_style_secondary_2: section.settings.button_style_secondary_2,
      wrapper_class: 'link-panels__header',
      heading_class: 'link-panels__heading',
      content_text_class: 'link-panels__section-content',
      button_container_class: 'link-panels__section-buttons'
    -%}

    <ul
      class="link-panels__grid grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
      role="list"
    >
      {%- for block in section.blocks -%}
        {%- if block.type == 'panel' -%}
          <li
            class="link-panels__item grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            <a
              class="link-panels__panel"
              style="background-color: {{ block.settings.background_color }};"
              {% if block.settings.link != blank %}
                href="{{ block.settings.link }}"
                {% if block.settings.link_target %}
                  target="_blank"
                  rel="noopener noreferrer"
                {% endif %}
              {% else %}
                role="link"
                aria-disabled="true"
              {% endif %}
              {% unless block.settings.headline == blank %}
                aria-label="{{ block.settings.headline | escape }}"
              {% endunless %}
            >
              {%- if block.settings.image != blank -%}
                {%- capture image_sizes -%}(min-width: 990px) calc((100vw - 10rem) / {{ section.settings.columns_desktop }}), (min-width: 750px) calc((100vw - 6rem) / {{ section.settings.columns_mobile }}), calc(100vw - 3rem){%- endcapture -%}
                <div class="link-panels__image-wrapper">
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      class: 'link-panels__image',
                      loading: 'lazy',
                      widths: '200, 400, 600, 800',
                      sizes: image_sizes
                  }}
                </div>
              {%- endif -%}

              {%- unless block.settings.headline == blank -%}
                <span
                  class="link-panels__label"
                  style="background-color: {{ block.settings.text_background_color }}; color: {{ block.settings.heading_color }};"
                >
                  {{- block.settings.headline | escape -}}
                </span>
              {%- endunless -%}
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>
</div>

{% schema %}
{
  "name": "Link panels",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "supersize", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h2", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "h3", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "h4", "label": "t:sections.all.heading_size.options__5.label" },
        { "value": "h5", "label": "t:sections.all.heading_size.options__6.label" },
        { "value": "h6", "label": "t:sections.all.heading_size.options__7.label" },
        { "value": "small", "label": "t:sections.all.heading_size.options__8.label" }
      ]
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "info": "Optional body text displayed below the heading."
    },
    {
      "type": "header",
      "content": "Section buttons"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button 1 label",
      "info": "Leave blank to hide."
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button 1 link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary_1",
      "label": "Button 1 — use outline style",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 label",
      "info": "Leave blank to hide."
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary_2",
      "label": "Button 2 — use outline style",
      "default": true
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 2,
      "label": "Columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "default": "1",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ]
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "text",
          "id": "headline",
          "label": "Headline",
          "default": "Panel title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        },
        {
          "type": "checkbox",
          "id": "link_target",
          "label": "Open link in new tab",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Panel image"
        },
        {
          "type": "header",
          "content": "Colours"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Panel background colour",
          "default": "#004E9A"
        },
        {
          "type": "color",
          "id": "text_background_color",
          "label": "Text background colour",
          "default": "#0099A8"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Headline colour",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Link panels",
      "blocks": [
        {
          "type": "panel",
          "settings": {
            "headline": "Joyful Deals",
            "background_color": "#004E9A",
            "text_background_color": "#0099A8",
            "heading_color": "#ffffff"
          }
        },
        {
          "type": "panel",
          "settings": {
            "headline": "Starter Kit",
            "background_color": "#0099A8",
            "text_background_color": "#F5A623",
            "heading_color": "#ffffff"
          }
        }
      ]
    }
  ]
}
{% endschema %}
