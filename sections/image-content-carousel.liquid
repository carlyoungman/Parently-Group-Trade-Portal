{%- render 'section-padding-style' -%}

{%- style -%}
  #shopify-section-{{ section.id }} .image-content-carousel__bg {
    background-color: {{ section.settings.content_bg_color }};
  }
{%- endstyle -%}

<div class="image-content-carousel color-scheme-1 section-{{ section.id }}-padding">
  <div class="page-width">

    {%- comment -%} ── Section header ── {%- endcomment -%}
    {%- render 'section-heading-group',
      heading: section.settings.heading,
      heading_size: section.settings.heading_size,
      content: section.settings.content,
      button_label_1: section.settings.button_label_1,
      button_link_1: section.settings.button_link_1,
      button_style_secondary_1: section.settings.button_style_secondary_1,
      button_label_2: section.settings.button_label_2,
      button_link_2: section.settings.button_link_2,
      button_style_secondary_2: section.settings.button_style_secondary_2,
      wrapper_class: 'image-content-carousel__header',
      heading_class: 'image-content-carousel__heading',
      content_text_class: 'image-content-carousel__section-content',
      button_container_class: 'image-content-carousel__section-buttons'
    -%}

    {%- comment -%} ── Carousel ── {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div
        class="image-content-carousel__stage{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        style="--ic-carousel-bg: {{ section.settings.content_bg_color }};"
      >

        {%- comment -%} Static coloured background (desktop, right side) {%- endcomment -%}
        <div class="image-content-carousel__bg" aria-hidden="true"></div>

        <slider-component class="image-content-carousel__slider-component">

          <ul
            id="Slider-{{ section.id }}"
            class="image-content-carousel__track slider slider--everywhere"
            role="list"
            aria-live="polite"
            aria-atomic="true"
          >
            {%- for block in section.blocks -%}
              <li
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="image-content-carousel__slide slider__slide"
                {{ block.shopify_attributes }}
                role="group"
                aria-roledescription="slide"
                aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                tabindex="-1"
              >

                {%- comment -%} Left — main image {%- endcomment -%}
                <div class="image-content-carousel__slide-image">
                  {%- if block.settings.image != blank -%}
                    {%- liquid
                      assign fetch_priority = 'auto'
                      if section.index == 1 and forloop.first
                        assign fetch_priority = 'high'
                      endif
                    -%}
                    {{
                      block.settings.image
                      | image_url: width: 900
                      | image_tag:
                        widths: '400, 600, 900',
                        sizes: '(min-width: 750px) 42vw, 100vw',
                        loading: 'lazy',
                        fetchpriority: fetch_priority,
                        class: 'image-content-carousel__image'
                    }}
                  {%- else -%}
                    {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg image-content-carousel__placeholder' }}
                  {%- endif -%}
                </div>

                {%- comment -%} Right — text content {%- endcomment -%}
                <div class="image-content-carousel__slide-content">

                  {%- if block.settings.heading != blank -%}
                    <h3 class="image-content-carousel__slide-heading">
                      {{ block.settings.heading }}
                    </h3>
                  {%- endif -%}

                  {%- if block.settings.content != blank -%}
                    <div class="image-content-carousel__slide-text rte {{ block.settings.text_style }}">
                      {{ block.settings.content }}
                    </div>
                  {%- endif -%}

                  {%- if block.settings.content_image != blank -%}
                    <div class="image-content-carousel__slide-badge">
                      {{
                        block.settings.content_image
                        | image_url: width: 300
                        | image_tag:
                          widths: '100, 150, 200, 300',
                          sizes: '120px',
                          loading: 'lazy',
                          class: 'image-content-carousel__badge-image'
                      }}
                    </div>
                  {%- endif -%}

                  {%- render 'button-pair',
                    button_label_1: block.settings.button_label_1,
                    button_link_1: block.settings.button_link_1,
                    button_style_secondary_1: block.settings.button_style_secondary_1,
                    button_label_2: block.settings.button_label_2,
                    button_link_2: block.settings.button_link_2,
                    button_style_secondary_2: block.settings.button_style_secondary_2,
                    container_class: 'image-content-carousel__slide-buttons'
                  -%}

                </div>
              </li>
            {%- endfor -%}
          </ul>

          {%- if section.blocks.size > 1 -%}
            <div class="image-content-carousel__nav slider-buttons">
              <button
                type="button"
                class="slider-button slider-button--prev"
                name="previous"
                aria-label="{{ 'general.slider.previous_slide' | t }}"
                aria-controls="Slider-{{ section.id }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </button>
              <button
                type="button"
                class="slider-button slider-button--next"
                name="next"
                aria-label="{{ 'general.slider.next_slide' | t }}"
                aria-controls="Slider-{{ section.id }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
          {%- endif -%}

        </slider-component>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Image content carousel",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Awards & Accolades",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "supersize", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h2", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "h3", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "h4", "label": "t:sections.all.heading_size.options__5.label" },
        { "value": "h5", "label": "t:sections.all.heading_size.options__6.label" },
        { "value": "h6", "label": "t:sections.all.heading_size.options__7.label" },
        { "value": "small", "label": "t:sections.all.heading_size.options__8.label" },
        { "value": "h0", "label": "Extra large" }
      ]
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "info": "Optional body text displayed below the section heading."
    },
    {
      "type": "header",
      "content": "Section buttons"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button 1 label",
      "info": "Leave blank to hide."
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button 1 link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary_1",
      "label": "Button 1 — use outline style",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 label",
      "info": "Leave blank to hide."
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary_2",
      "label": "Button 2 — use outline style",
      "default": true
    },
    {
      "type": "header",
      "content": "Carousel appearance"
    },
    {
      "type": "color",
      "id": "content_bg_color",
      "label": "Content background colour",
      "default": "#5a9b5f"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide image"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Slide heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "default": "<p>Describe this slide in a short, clear paragraph.</p>",
          "label": "Content"
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            { "value": "body", "label": "Body" },
            { "value": "large", "label": "Large" },
            { "value": "subtitle", "label": "Subheading" },
            { "value": "caption-with-letter-spacing", "label": "Uppercase" }
          ],
          "default": "body",
          "label": "Style"
        },
        {
          "type": "image_picker",
          "id": "content_image",
          "label": "Content image",
          "info": "Optional image within the content panel — e.g. award badge or certification logo."
        },
        {
          "type": "header",
          "content": "Button 1"
        },
        {
          "type": "text",
          "id": "button_label_1",
          "label": "Button 1 label",
          "info": "Leave blank to hide."
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Button 1 link"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary_1",
          "label": "Button 1 — use outline style",
          "default": false
        },
        {
          "type": "header",
          "content": "Button 2"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Button 2 label",
          "info": "Leave blank to hide."
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Button 2 link"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary_2",
          "label": "Button 2 — use outline style",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with content carousel",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
