{%- render 'section-padding-style' -%}

{%- style -%}
  #shopify-section-{{ section.id }} .logo-carousel__image-wrapper {
    height: {{ section.settings.logo_height }}px;
    {%- if section.settings.image_ratio == 'landscape' -%}
      width: {{ section.settings.logo_height | times: 1.5 | round }}px;
    {%- elsif section.settings.image_ratio == 'square' -%}
      width: {{ section.settings.logo_height }}px;
    {%- elsif section.settings.image_ratio == 'wide' -%}
      width: {{ section.settings.logo_height | times: 1.778 | round }}px;
    {%- endif -%}
  }

  #shopify-section-{{ section.id }} .logo-carousel__list--grid {
    --logos-per-row: {{ section.settings.logos_per_row_desktop }};
  }
{%- endstyle -%}

{%- liquid
  assign carousel_enabled = section.settings.enable_carousel
-%}

<div class="logo-carousel color-scheme-1">
  <div class="page-width section-{{ section.id }}-padding">

    {%- unless section.settings.title == blank -%}
      <div class="logo-carousel__title-wrapper">
        <h2 class="logo-carousel__title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endunless -%}

    {%- if carousel_enabled -%}
      <slider-component class="slider-mobile-gutter logo-carousel__slider-component{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <ul
          class="logo-carousel__list slider slider--everywhere"
          id="Slider-{{ section.id }}"
          role="list"
        >
          {%- for block in section.blocks -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="logo-carousel__item slider__slide"
              {{ block.shopify_attributes }}
            >
              {%- assign alt_text = block.settings.image_alt | default: block.settings.image.alt | escape -%}
              {%- render 'link-card',
                link: block.settings.link,
                link_class: 'logo-carousel__link',
                image: block.settings.image,
                image_url_width: 400,
                image_tag_widths: '100, 150, 200, 300, 400',
                image_tag_sizes: '200px',
                image_class: 'logo-carousel__image',
                image_alt: alt_text,
                wrapper_class: 'logo-carousel__image-wrapper',
                placeholder_class: 'logo-carousel__image-wrapper--placeholder',
                placeholder_name: 'image'
              -%}
            </li>
          {%- endfor -%}
        </ul>

        <div class="slider-buttons logo-carousel__slider-buttons">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
        </div>
      </slider-component>

    {%- else -%}
      <ul
        class="logo-carousel__list logo-carousel__list--grid{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        role="list"
      >
        {%- for block in section.blocks -%}
          <li
            class="logo-carousel__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            {%- assign alt_text = block.settings.image_alt | default: block.settings.image.alt | escape -%}
            {%- render 'link-card',
              link: block.settings.link,
              link_class: 'logo-carousel__link',
              image: block.settings.image,
              image_url_width: 400,
              image_tag_widths: '100, 150, 200, 300, 400',
              image_tag_sizes: '200px',
              image_class: 'logo-carousel__image',
              image_alt: alt_text,
              wrapper_class: 'logo-carousel__image-wrapper',
              placeholder_class: 'logo-carousel__image-wrapper--placeholder',
              placeholder_name: 'image'
            -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Logo carousel",
  "tag": "section",
  "class": "section section-logo-carousel",
  "max_blocks": 20,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Explore our brands",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.all.heading_size.label",
      "default": "h2",
      "options": [
        {
          "value": "supersize",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__5.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options__6.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_size.options__7.label"
        },
        {
          "value": "small",
          "label": "t:sections.all.heading_size.options__8.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_carousel",
      "default": true,
      "label": "Enable carousel",
      "info": "When enabled, logos scroll horizontally. When disabled, logos display as a static grid."
    },
    {
      "type": "header",
      "content": "Logo appearance"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 40,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80,
      "label": "Logo height"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "default": "adapt",
      "label": "Image ratio",
      "info": "Sets the width of each logo container relative to its height. Use 'Adapt to image' to preserve each logo's natural proportions.",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "landscape",
          "label": "Landscape (3:2)"
        },
        {
          "value": "square",
          "label": "Square (1:1)"
        },
        {
          "value": "wide",
          "label": "Wide (16:9)"
        }
      ]
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "logos_per_row_desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 6,
      "label": "Logos per row (desktop)",
      "info": "Applies when carousel is disabled."
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Alt text",
          "info": "Describe the logo for screen readers. If blank, uses the uploaded image's alt text."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo carousel",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
