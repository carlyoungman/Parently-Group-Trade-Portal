{% schema %}
{
  "name": "Image Downloads",
  "tag": "section",
  "class": "section-image-downloads",
  "settings": [
    {
      "type": "header",
      "content": "Page content"
    },
    {
      "type": "text",
      "id": "page_title",
      "label": "Page title",
      "default": "Image Downloads"
    },
    {
      "type": "textarea",
      "id": "page_intro",
      "label": "Intro text",
      "default": "Download approved campaign, product, and lifestyle assets for your channels. Packs updated each season."
    },
    {
      "type": "header",
      "content": "Brand tabs"
    },
    {
      "type": "text",
      "id": "brand_1_label",
      "label": "Brand 1 tab label",
      "default": "David Luke"
    },
    {
      "type": "text",
      "id": "brand_2_label",
      "label": "Brand 2 tab label",
      "default": "Grass & Air"
    },
    {
      "type": "text",
      "id": "brand_3_label",
      "label": "Brand 3 tab label",
      "default": "Lelli Kelly"
    },
    {
      "type": "text",
      "id": "brand_4_label",
      "label": "Brand 4 tab label",
      "default": "Term"
    },
    {
      "type": "text",
      "id": "brand_5_label",
      "label": "Brand 5 tab label",
      "default": "Little Classmates"
    },
    {
      "type": "text",
      "id": "brand_6_label",
      "label": "Brand 6 tab label",
      "default": "Juco"
    },
    {
      "type": "header",
      "content": "Access control"
    },
    {
      "type": "checkbox",
      "id": "require_login",
      "label": "Require customer login to view downloads",
      "default": true
    },
    {
      "type": "text",
      "id": "required_tag",
      "label": "Required customer tag (leave blank to allow all logged-in customers)",
      "info": "e.g. 'trade' — only customers with this tag will see the page content"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / button colour",
      "default": "#4EA043"
    },
    {
      "type": "color",
      "id": "tab_active_color",
      "label": "Active tab underline colour",
      "default": "#4EA043"
    }
  ],
  "blocks": [
    {
      "type": "brand_section",
      "name": "Brand asset section",
      "settings": [
        {
          "type": "select",
          "id": "brand",
          "label": "Brand",
          "options": [
            { "value": "dl",   "label": "David Luke" },
            { "value": "ga",   "label": "Grass & Air" },
            { "value": "lk",   "label": "Lelli Kelly" },
            { "value": "term", "label": "Term" },
            { "value": "lc",   "label": "Little Classmates" },
            { "value": "juco", "label": "Juco" }
          ],
          "default": "dl"
        },
        {
          "type": "text",
          "id": "section_title",
          "label": "Section heading",
          "info": "e.g. 'Summer 2026 campaign' or 'AW26 collection'",
          "default": "SS26 collection"
        }
      ]
    },
    {
      "type": "asset",
      "name": "Asset",
      "settings": [
        {
          "type": "select",
          "id": "brand",
          "label": "Brand this asset belongs to",
          "options": [
            { "value": "dl",   "label": "David Luke" },
            { "value": "ga",   "label": "Grass & Air" },
            { "value": "lk",   "label": "Lelli Kelly" },
            { "value": "term", "label": "Term" },
            { "value": "lc",   "label": "Little Classmates" },
            { "value": "juco", "label": "Juco" }
          ],
          "default": "dl"
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail image",
          "info": "Shown in the grid. Ideally 4:3 ratio, 800×600px minimum."
        },
        {
          "type": "text",
          "id": "asset_name",
          "label": "Asset name",
          "default": "DL-AW26-HERO-01"
        },
        {
          "type": "url",
          "id": "asset_url",
          "label": "Download URL",
          "info": "Paste the Shopify Files CDN URL for this image or file"
        },
        {
          "type": "text",
          "id": "asset_size",
          "label": "File size and type",
          "info": "Displayed under the thumbnail — e.g. '6.2 MB · JPG'",
          "default": "0 MB · JPG"
        },
        {
          "type": "select",
          "id": "asset_type",
          "label": "Asset type",
          "options": [
            { "value": "campaign",  "label": "Campaign" },
            { "value": "product",   "label": "Product" },
            { "value": "lifestyle", "label": "Lifestyle" },
            { "value": "logos",     "label": "Logos" }
          ],
          "default": "campaign"
        }
      ]
    },
    {
      "type": "zip_pack",
      "name": "ZIP asset pack",
      "settings": [
        {
          "type": "select",
          "id": "brand",
          "label": "Brand this pack belongs to",
          "options": [
            { "value": "dl",   "label": "David Luke" },
            { "value": "ga",   "label": "Grass & Air" },
            { "value": "lk",   "label": "Lelli Kelly" },
            { "value": "term", "label": "Term" },
            { "value": "lc",   "label": "Little Classmates" },
            { "value": "juco", "label": "Juco" }
          ],
          "default": "dl"
        },
        {
          "type": "text",
          "id": "pack_name",
          "label": "Pack name",
          "default": "AW26 — full asset pack"
        },
        {
          "type": "text",
          "id": "pack_detail",
          "label": "Pack detail line",
          "info": "e.g. '48 files · 142 MB · Updated 12 May 2026'",
          "default": "0 files · 0 MB"
        },
        {
          "type": "url",
          "id": "pack_url",
          "label": "ZIP download URL",
          "info": "Paste the Shopify Files CDN URL for the ZIP file"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Downloads",
      "blocks": [
        {
          "type": "brand_section",
          "settings": {
            "brand": "dl",
            "section_title": "AW26 schoolwear"
          }
        },
        {
          "type": "brand_section",
          "settings": {
            "brand": "ga",
            "section_title": "Summer 2026 campaign"
          }
        }
      ]
    }
  ]
}
{% endschema %}
